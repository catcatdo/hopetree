rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // HopeTree public encouragement messages only
    match /comments/{docId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly(['name', 'message', 'timestamp']) &&
        request.resource.data.name is string &&
        request.resource.data.message is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 10 &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 50;

      // client update/delete not needed for this app
      allow update, delete: if false;
    }
  }
}
